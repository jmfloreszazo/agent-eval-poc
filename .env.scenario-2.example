# Template for scenario-2 (.env.scenario-2 at the repo root).
#
# Copy to `.env.scenario-2` and fill in the values. The file is gitignored —
# never commit real keys. `scenario-2/infra/deploy.ps1` generates it for
# you after deploying the Foundry stack.
#
# Tip: regenerate the API key with
#   az cognitiveservices account keys regenerate \
#       -n <foundry-account> -g <rg> --key-name Key1
#
# ----- Azure AI Foundry (account + project + gpt-4o-mini deployment) -----
AZURE_AI_FOUNDRY_ACCOUNT=<your-foundry-account-name>
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-foundry-account>.cognitiveservices.azure.com/
AZURE_AI_PROJECT_NAME=<your-foundry-project>
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-foundry-project>
AZURE_AI_FOUNDRY_API_KEY=<replace-me>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ----- Observability (Application Insights + Log Analytics) -----
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<guid>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=<guid>
LOG_ANALYTICS_WORKSPACE_ID=<workspace-guid>
LOG_ANALYTICS_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.OperationalInsights/workspaces/<law-name>
AZURE_RESOURCE_GROUP=<rg>
AZURE_SUBSCRIPTION_ID=<sub-id>

# ----- Hosted agent (continuous evaluation) -----
AZURE_AI_AGENT_NAME=scenario2-finops-agent
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_AI_PROJECT_MI_PRINCIPAL_ID=<project-managed-identity-guid>
