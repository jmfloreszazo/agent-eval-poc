# Template for scenario-1 (.env at the repo root).
#
# Copy to `.env` and fill in the values. .env is gitignored — never commit
# real keys. Regenerate the file by running `scenario-1/infra/deploy.ps1`,
# which writes it for you.
#
# ----- Azure OpenAI (used as both the agent's LLM and DeepEval's judge) -----
USE_AZURE_OPENAI=YES
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
AZURE_OPENAI_API_KEY=<replace-me>
AZURE_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_MODEL_NAME=gpt-4o-mini
AZURE_MODEL_VERSION=2024-07-18
OPENAI_API_VERSION=2024-10-21
USE_REAL_LLM=YES
