# Template for scenario-3 (.env.scenario-3 at the repo root). Copy to
# `.env.scenario-3` and fill in the values. The file is gitignored —
# never commit real keys.
#
# Generated by `scenario-3/infra/deploy.ps1`. The optional APIM AI Gateway
# variables are appended by `scenario-3/infra/deploy_aigateway.ps1` if you
# choose to provision Layer 2 of the governance architecture.
#
# Tip: regenerate the Foundry key with
#   az cognitiveservices account keys regenerate \
#       -n <foundry-account> -g <rg> --key-name Key1
#
# ----- Azure AI Foundry (dedicated to scenario-3 — separate from scenario-2) -----
AZURE_AI_FOUNDRY_ACCOUNT=<your-foundry-account-name>
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-foundry-account>.cognitiveservices.azure.com/
AZURE_AI_PROJECT_NAME=<your-foundry-project>
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-foundry-project>
AZURE_AI_FOUNDRY_API_KEY=<replace-me>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ----- Observability (used by corp.py / telemetry.py) -----
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<guid>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=<guid>
APP_INSIGHTS_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.Insights/components/<appi-name>
LOG_ANALYTICS_WORKSPACE_ID=<workspace-guid>
LOG_ANALYTICS_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.OperationalInsights/workspaces/<law-name>
AZURE_RESOURCE_GROUP=<rg>
AZURE_SUBSCRIPTION_ID=<sub-id>

# ----- Project MI (Foundry continuous eval) -----
AZURE_AI_PROJECT_MI_PRINCIPAL_ID=<project-managed-identity-guid>

# ----- Layer 2: APIM AI Gateway (optional) -----
# Populated by scenario-3/infra/deploy_aigateway.ps1.
# AZURE_OPENAI_GATEWAY_ENDPOINT=https://<apim-name>.azure-api.net/
# AZURE_OPENAI_GATEWAY_SUBSCRIPTION_KEY=<apim-subscription-primary-key>
# AZURE_OPENAI_GATEWAY_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_GATEWAY_API_VERSION=2024-10-21
# AZURE_OPENAI_GATEWAY_APIM_NAME=<apim-name>
# AZURE_CONTENT_SAFETY_ENDPOINT=https://<cs-name>.cognitiveservices.azure.com/

# ----- Layer 1: GitHub Copilot audit pull (optional) -----
# Used by scenario-3/tools/copilot_audit_pull.py; not required at runtime.
# GITHUB_TOKEN=<fine-grained-pat-with-read:audit_log>
# GITHUB_ENTERPRISE=<your-enterprise-slug>
# GITHUB_ORG=<your-org-slug>
