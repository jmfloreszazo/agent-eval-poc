# --- .NET ---
bin/
obj/
*.user
.vs/

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.deepeval/
.deepeval-cache/
*.egg-info/

# --- Secrets ---
# Catch-all: every .env* file is treated as secrets unless it ends in
# .example. Add new .env.<scope> files freely; only the .example
# template is allowed to land in git.
.env
.env.*
!.env.example
!.env.*.example

# --- Run artifacts ---
# The example trajectory (scenario-1/data/trajectory.json) IS versioned so
# the evals can run without compiling. Generated trajectories aren't.
/agent/trajectory.json
/scenario-1/data/trajectory.json
/scenario-2/data/traces.jsonl
/scenario-2/data/quality.jsonl
/scenario-2/data/safety.jsonl
/scenario-2/data/governance_report.*
/scenario-3/data/traces.jsonl
/scenario-3/data/judge.jsonl
/scenario-3/data/judge_summary.json
/scenario-3/data/quality.jsonl
/scenario-3/data/safety.jsonl
/scenario-3/.copilot-audit-cursor.json

# VS Code extension build output
/vscode-ext/*/node_modules/
/vscode-ext/*/out/
/vscode-ext/*/*.vsix

# --- Scenario 4 (source-control attribution) local artefacts ---
# The post-commit example hook writes a local audit logbook under .git/;
# it stays inside .git/ by default. Anything generated by the scripts that
# users may redirect to the working tree goes here.
/scenario-4/.audit/
/scenario-4/.tmp/
/scenario-4/summary.md

# --- OS / editors ---
.DS_Store
.idea/
*.swp
